{
  "name": "pixel-drawing",
  "version": "0.0.1",
  "description": "",
  "private": true,
  "source": [
    "src/client/index.html",
    "src/client/admin.html",
    "src/client/erase.html"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev:client": "parcel --dist-dir=dist/public",
    "dev:server": "NODE_ENV=development;ADMIN_PASS=testtest; yarn build:server && yarn start",
    "build": "yarn clean && yarn build:client && yarn build:server",
    "build:client": "parcel build --dist-dir=dist/public",
    "build:server": "tsc -p ./tsconfig.server.json",
    "prettier": "prettier --config .prettierrc --write .",
    "clean": "rimraf dist && rimraf .parcel-cache",
    "typecheck": "tsc --noEmit && tsc -p ./tsconfig.server.json --noEmit"
  },
  "author": "Ingo Valente",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "redis": "^4.6.12",
    "rimraf": "^6.1.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@parcel/packager-raw-url": "^2.16.4",
    "@parcel/transformer-sass": "^2.16.4",
    "@parcel/transformer-webmanifest": "^2.16.4",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.19",
    "@types/ws": "^8.5.10",
    "buffer": "^5.5.0||^6.0.0",
    "parcel": "^2.16.4",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "resolutions": {
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.19.0"
  },
  "browserslist": "> 0.5%, last 2 versions, not dead"
}
